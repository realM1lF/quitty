# QuittyPro — Umgebungsvariablen
# Kopieren nach .env bzw. in Netlify → Site settings → Environment variables eintragen.

# Supabase (App → Postgres/Auth/Storage). Ohne diese Werte läuft die App im Demo-Modus.
VITE_SUPABASE_URL=https://dein-projekt.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-key

# Anthropic API-Key für die Beleg-Erkennung (Netlify Function `ocr`, nur serverseitig)
ANTHROPIC_API_KEY=sk-ant-...
